# Supabase project URL — found in Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key — safe to expose in client-side code
SUPABASE_KEY=your-anon-public-key

# Admin account email — used as the identifier for the single admin account
# Create this account once via Supabase Dashboard > Authentication > Users
NUXT_PUBLIC_ADMIN_EMAIL=martin.kristensen096@gmail.com
